<div class="col-12 col-sm-12 col-md-4 col-lg-4 footer-column">
  <div class="row text-start">
    <div class="col-5 footer-links">
      <% left_column_links.each do |link| %>
        <%= link_to link[:url], target: link[:target] do %>
          <h6><%= t(link[:text]) %></h6>
        <% end %>
      <% end %>
    </div>
    <div class="col-6 footer-links">
      <% right_column_links.each do |link| %>
        <%= link_to link[:url], target: link[:target] do %>
          <h6><%= t(link[:text]) %></h6>
        <% end %>
      <% end %>
      <h6>
  <%= link_to t("layout.footer.link_to_forum"), "https://circuitverse.org/community", target: "_blank" %>
</h6>
    </div>
  </div>
</div>
