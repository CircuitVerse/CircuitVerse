<div class="col-12 col-sm-6 footer-links-column">
  <div class="row text-start">
    <div class="col-6 footer-links">
    <h2 class="footer-heading-text"><%= t("layout.footer.community") %></h2>
      <% left_column_links.each do |link| %>
        <%= link_to link[:url], target: link[:target] do %>
          <h6><%= t(link[:text]) %></h6>
        <% end %>
      <% end %>
    </div>
    <div class="col-6 footer-links">
    <h2 class="footer-heading-text"><%= t("layout.footer.resources") %></h2>
      <% right_column_links.each do |link| %>
        <%= link_to link[:url], target: link[:target] do %>
          <h6><%= t(link[:text]) %></h6>
        <% end %>
      <% end %>
      <% if forum_enabled? %>
        <h6><%= link_to t("layout.footer.link_to_forum"), simple_discussion_path %></h6>
      <% end %>
    </div>
  </div>
</div>
