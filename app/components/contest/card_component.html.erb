<%= link_to contest_path(@contest.id),
            class: "text-decoration-none contest-card",
            data:  { contest_id: @contest.id },
            id:    "contest-#{@contest.id}" do %>
  <div class="contest-container h-100">
    <div class="contest-container-card-image">
       <%= image_tag "empty_project/default_contest_card.png",alt: t("contest.contest_container.default_contest_card_img_alt"), class:"contest-card-image" %>
      <% if @contest.live? %>
        <div class="contest-container-status-live">
          <span class="contest-container-status-dot"></span>
          <span class="contest-container-status-text"><%= t("contest.status.live") %></span>
        </div>
      <% else %>
        <div class="contest-container-status">
          <span class="contest-container-status-text"><%= t("contest.status.completed") %></span>
        </div>
      <% end %>
    </div>
    <div class="contest-container-details">
      <div class="contest-container-details-number">
        <span class="contest-container-details-number-link">
          <%= t("contest.contest_container.contest_id") %> #<%= @contest.id %>
        </span>
      </div>
      <div class="contest-container-details-entries">
        <%= image_tag "svgs/user.svg", alt: t("contest.contest_container.entries_alt"),class:"entries-image" %>
        <span>
          <%= @contest.submissions_count %> <%= t("contest.contest_container.entries") %>
        </span>
      </div>
      <div class="contest-container-details-description">
        <span> <%= t("contest.contest_container.description") %> </span>
      </div>
    </div>
  </div>
<% end %>
