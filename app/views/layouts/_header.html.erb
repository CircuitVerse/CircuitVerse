<script type="text/javascript">
  (function() {
    function initializeTheme() {
      const body = document.body;
      const html = document.documentElement;
      const themeIcon = document.getElementById('theme-icon');
      const darkModeToggle = document.getElementById('dark-mode-toggle');
      
      const isSimulator = window.location.pathname.includes('/simulator') || 
                          window.location.pathname.includes('/editor');
      const savedTheme = localStorage.getItem('theme');

      if (isSimulator) {
        
        html.classList.remove('dark-mode');
        body.classList.remove('dark-mode');
        if (themeIcon) themeIcon.classList.replace('fa-sun', 'fa-moon');
        if (darkModeToggle) darkModeToggle.style.display = 'none';
      } else {
        if (savedTheme === 'dark') {
          html.classList.add('dark-mode');
          body.classList.add('dark-mode');
          if (themeIcon) themeIcon.classList.replace('fa-moon', 'fa-sun');
        } else {
          html.classList.remove('dark-mode');
          body.classList.remove('dark-mode');
          if (themeIcon) themeIcon.classList.replace('fa-sun', 'fa-moon');
        }
        if (darkModeToggle) darkModeToggle.style.display = 'flex';
      }
    }

   
    function setupNavbarFeatures() {
    if (window.__navbarFeaturesInitialized) return;
    window.__navbarFeaturesInitialized = true;
      const navbar = document.querySelector('.navbar');
      const searchIcons = document.querySelectorAll(".fa-search");
      const searchBar = document.querySelector(".navbar-search-active");

   
      window.addEventListener('scroll', () => {
        if (navbar) {
          window.scrollY > 0 ? navbar.classList.add('affix') : navbar.classList.remove('affix');
        }
      }, { passive: true });

      
      searchIcons.forEach(icon => {
        icon.addEventListener("click", () => {
          const isActive = icon.classList.contains("active");
          searchIcons.forEach(i => i.classList.toggle("active", !isActive));
          if (searchBar) searchBar.style.display = isActive ? "none" : "block";
        });
      });

    
      document.querySelectorAll("[data-bs-toggle='dropdown']").forEach(trigger => {
        trigger.addEventListener("show.bs.dropdown", () => trigger.classList.add("rotate180"));
        trigger.addEventListener("hide.bs.dropdown", () => trigger.classList.remove("rotate180"));
      });

     
      const dropBtn = document.getElementById('dropdownButton');
      const collapseEl = document.getElementById("collapsed-navbar");
      if (dropBtn && collapseEl) {
        dropBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const collapse = bootstrap.Collapse.getInstance(collapseEl) || new bootstrap.Collapse(collapseEl);
          collapse.toggle();
        });
      }
    }

  
    
  
    document.addEventListener("click", function(e) {
      const toggle = e.target.closest('#dark-mode-toggle');
      if (!toggle || window.location.pathname.includes('/simulator')) return;
      
      e.preventDefault();
      document.body.classList.toggle('dark-mode');
      document.documentElement.classList.toggle('dark-mode');
      
      const isDark = document.body.classList.contains('dark-mode');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');

      const icon = document.getElementById('theme-icon');
      if (icon) {
        isDark ? icon.classList.replace('fa-moon', 'fa-sun') : 
                 icon.classList.replace('fa-sun', 'fa-moon');
      }
    });

    
    document.addEventListener("DOMContentLoaded", () => {
      initializeTheme();
      setupNavbarFeatures();
    });
    
    document.addEventListener("turbolinks:load", () => {
      initializeTheme();
      setupNavbarFeatures();
    });
    
    
    document.addEventListener("turbo:load", () => {
      initializeTheme();
      setupNavbarFeatures();
    });

  })();
</script>
