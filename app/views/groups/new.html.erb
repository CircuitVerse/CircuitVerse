<% content_for :title, t("groups.new.title") %>

<style>
.cv-new-group-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
  margin-top: 16px;
}
@media (max-width: 768px) {
  .cv-new-group-layout { grid-template-columns: 1fr; }
  .cv-new-group-preview { display: none; }
}
.cv-new-group-preview {
  background: #E1F5EE;
  border-radius: 12px;
  padding: 28px 24px;
  position: sticky;
  top: 80px;
}
.cv-preview-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #0F6E56;
  font-weight: 700;
  margin-bottom: 16px;
}
.cv-preview-icon-row {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 16px;
}
.cv-preview-icon {
  width: 48px;
  height: 48px;
  background: #1D9E75;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cv-preview-icon svg { color: white; }
.cv-preview-name {
  font-size: 1.2rem;
  font-weight: 700;
  color: #0F6E56;
  word-break: break-word;
  line-height: 1.3;
}
.cv-preview-placeholder {
  color: #94c5b5;
  font-style: italic;
}
.cv-preview-meta {
  font-size: 0.8rem;
  color: #0F6E56;
  opacity: 0.75;
  margin-top: 4px;
}
.cv-preview-divider {
  border: none;
  border-top: 1px solid rgba(29,158,117,0.25);
  margin: 16px 0;
}
.cv-preview-stat-row {
  display: flex;
  gap: 16px;
}
.cv-preview-stat {
  text-align: center;
}
.cv-preview-stat-number {
  font-size: 1.4rem;
  font-weight: 700;
  color: #0F6E56;
}
.cv-preview-stat-label {
  font-size: 0.7rem;
  color: #0F6E56;
  opacity: 0.7;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.cv-preview-domain-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 12px;
  font-size: 0.8rem;
  color: #0F6E56;
  opacity: 0.8;
}
.cv-domain-pill {
  background: rgba(29,158,117,0.15);
  border-radius: 20px;
  padding: 2px 10px;
  font-weight: 600;
  font-family: monospace;
  display: none;
}
</style>

<div class="container">
  <div class="row center-row">
    <div class="col">
      <h2 class="submain-heading"><%= t("groups.new.main_heading") %></h2>
      <p class="main-description"><%= t("groups.new.main_description_html") %></p>
    </div>
  </div>

  <div class="cv-new-group-layout">
    <div class="groups-background-card">
      <%= render "form", group: @group %>
    </div>

    <div class="cv-new-group-preview" aria-hidden="true">
      <div class="cv-preview-label">Preview</div>
      <div class="cv-preview-icon-row">
        <div class="cv-preview-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <div>
          <div id="preview-name" class="cv-preview-name cv-preview-placeholder">Group Name</div>
          <div class="cv-preview-meta">Primary Mentor: <%= current_user.name %></div>
        </div>
      </div>
      <hr class="cv-preview-divider">
      <div class="cv-preview-stat-row">
        <div class="cv-preview-stat">
          <div class="cv-preview-stat-number">0</div>
          <div class="cv-preview-stat-label">Members</div>
        </div>
        <div class="cv-preview-stat">
          <div class="cv-preview-stat-number">0</div>
          <div class="cv-preview-stat-label">Assignments</div>
        </div>
        <div class="cv-preview-stat">
          <div class="cv-preview-stat-number">0</div>
          <div class="cv-preview-stat-label">Submissions</div>
        </div>
      </div>
      <div id="preview-domain-row" class="cv-preview-domain-row" style="display:none;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Restricted to <span id="preview-domain" class="cv-domain-pill"></span>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var nameInput   = document.getElementById('group_name');
  var domainInput = document.getElementById('group_allowed_domain');
  var previewName = document.getElementById('preview-name');
  var previewDomainRow = document.getElementById('preview-domain-row');
  var previewDomain    = document.getElementById('preview-domain');

  if (nameInput && previewName) {
    nameInput.addEventListener('input', function() {
      var val = this.value.trim();
      if (val) {
        previewName.textContent = val;
        previewName.classList.remove('cv-preview-placeholder');
      } else {
        previewName.textContent = 'Group Name';
        previewName.classList.add('cv-preview-placeholder');
      }
    });
    // Trigger on load if editing
    if (nameInput.value) {
      previewName.textContent = nameInput.value;
      previewName.classList.remove('cv-preview-placeholder');
    }
  }

  if (domainInput && previewDomainRow) {
    domainInput.addEventListener('input', function() {
      var val = this.value.trim();
      if (val) {
        previewDomain.textContent = '@' + val;
        previewDomain.style.display = 'inline';
        previewDomainRow.style.display = 'flex';
      } else {
        previewDomainRow.style.display = 'none';
      }
    });
  }
})();
</script>
