<script>
// ── Assignment deadline local time conversion (unchanged) ───────
$(document).ready(function() {
  $('.groups-assignment-deadline').each(function() {
    var month   = $(this).data("month") - 1;
    var date    = new Date($(this).data("year"), month, $(this).data("day"),
                           $(this).data("hour"), $(this).data("minute"), $(this).data("second"), 0);
    var offset  = date.getTimezoneOffset();
    var local   = new Date(date.getTime() - offset * 60 * 1000);
    this.innerHTML = local;
  });

  // Delete assignment modal — set href
  $("#deleteassignmentModal").on("show.bs.modal", function(e) {
    var group      = $(e.relatedTarget).data('currentgroup');
    var assignment = $(e.relatedTarget).data('currentassignment');
    $(e.currentTarget).find('#groups-assignment-delete-button')
      .attr("href", "/groups/" + group.toString() + "/assignments/" + assignment.toString());
  });

  // Delete member modal — set href
  $("#deletememberModal").on("show.bs.modal", function(e) {
    var gm = $(e.relatedTarget).data('currentgroupmember');
    $(e.currentTarget).find('#groups-member-delete-button')
      .attr("href", "/group_members/" + gm.toString());
  });

  // Promote/demote modals — set form action
  $("#promote-member-modal").on("show.bs.modal", function(e) {
    var gm = $(e.relatedTarget).data('currentgroupmember');
    $(e.currentTarget).find('#groups-member-promote-button')
      .closest('form').attr("action", "/group_members/" + gm.toString());
  });

  $("#demote-member-modal").on("show.bs.modal", function(e) {
    var gm = $(e.relatedTarget).data('currentgroupmember');
    $(e.currentTarget).find('#groups-member-demote-button')
      .closest('form').attr("action", "/group_members/" + gm.toString());
  });
});

// ── Inline panel toggle ─────────────────────────────────────────
function toggleCvPanel(id) {
  var panel = document.getElementById(id);
  if (!panel) return;
  var isOpen = panel.classList.toggle('is-open');
  // Update aria-expanded on the triggering button
  document.querySelectorAll('[aria-controls="' + id + '"]').forEach(function(btn) {
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
}

function closeCvPanel(id) {
  var panel = document.getElementById(id);
  if (!panel) return;
  panel.classList.remove('is-open');
  document.querySelectorAll('[aria-controls="' + id + '"]').forEach(function(btn) {
    btn.setAttribute('aria-expanded', 'false');
  });
}

// ── Table column sort ───────────────────────────────────────────
(function() {
  var sortState = {};

  window.sortCvTable = function(tableId, colIdx, thEl) {
    var table = document.getElementById(tableId);
    if (!table) return;
    var tbody = table.querySelector('tbody');
    var rows  = Array.from(tbody.querySelectorAll('tr'));
    var key   = tableId + '_' + colIdx;
    var dir   = sortState[key] === 'asc' ? 'desc' : 'asc';
    sortState[key] = dir;

    rows.sort(function(a, b) {
      var av = (a.cells[colIdx] ? a.cells[colIdx].textContent.trim() : '');
      var bv = (b.cells[colIdx] ? b.cells[colIdx].textContent.trim() : '');
      return dir === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    });
    rows.forEach(function(r) { tbody.appendChild(r); });

    // Update arrow indicators
    table.querySelectorAll('th').forEach(function(th) {
      th.classList.remove('sorted');
      var arrow = th.querySelector('.cv-sort-arrow');
      if (arrow) arrow.textContent = '↕';
    });
    thEl.classList.add('sorted');
    var activeArrow = thEl.querySelector('.cv-sort-arrow');
    if (activeArrow) activeArrow.textContent = dir === 'asc' ? '↑' : '↓';
  };
})();
</script>
