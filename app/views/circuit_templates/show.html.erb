<% content_for :title, @template.name %>

<div class="container" style="padding-top: 30px; padding-bottom: 60px;">
  <div class="row center-row">
    <div class="col-12">
      <h1 class="submain-heading">
        <%= @template.name %>
        <% if user_signed_in? && @template.created_by_id == current_user.id %>
          <%= link_to "Edit", edit_circuit_template_path(@template),
              class: "btn primary-button groups-editname-primary-button" %>
        <% end %>
      </h1>
      <h4 class="group-mentor-heading">
        Created by <%= @template.created_by.name %> &middot;
        <%= time_ago_in_words(@template.created_at) %> ago
      </h4>
      <span class="badge <%= @template.public ? 'bg-success' : 'bg-secondary' %>">
        <%= @template.public ? "Public" : "Private" %>
      </span>
    </div>
  </div>

  <%# ── DESCRIPTION ────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
    <h3 class="mb-0">Description</h3>
  </div>
  <hr>
  <% if @template.description.present? %>
    <p><%= @template.description %></p>
  <% else %>
    <span class="null-text">No description added.</span>
  <% end %>

  <%# ── CIRCUIT DATA ────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
    <h3 class="mb-0">Circuit Data</h3>
  </div>
  <hr>
  <% if @template.circuit_data.present? %>
    <table class="table table-borderless groups-table">
      <thead class="groups-table-heading">
        <tr>
          <th>Key</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <% begin; parsed_data = @template.circuit_data.is_a?(String) ? JSON.parse(@template.circuit_data) : @template.circuit_data; rescue; parsed_data = {}; end; parsed_data.each do |key, value| %>
          <tr class="groups-table-rows">
            <td><strong><%= key.to_s.humanize %></strong></td>
            <td>
              <% if value.is_a?(Array) %>
                <%= value.length %> item<%= value.length == 1 ? "" : "s" %>
              <% elsif value.is_a?(Hash) %>
                <code style="font-size: 0.8rem;"><%= value.to_json.truncate(80) %></code>
              <% else %>
                <%= value %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <span class="null-text">No circuit data configured yet.</span>
  <% end %>

  <%# ── TEST CASES ──────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
    <h3 class="mb-0">Test Cases</h3>
    <% if user_signed_in? && @template.created_by_id == current_user.id && @assignments_using.any? %>
      <button type="button" class="btn primary-button"
              data-bs-toggle="modal" data-bs-target="#addTestCaseModal">
        Add Test Case
      </button>
    <% end %>
  </div>
  <hr>

  <% test_cases = @template.assignment_test_cases %>
  <% if test_cases.empty? %>
    <span class="null-text">No test cases have been added yet.</span>
  <% else %>
    <% test_cases.order(:position).each do |tc| %>
      <div class="groups-members-card" style="width: 100%; height: auto; margin: 0 0 15px; padding: 12px 15px;">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <strong><%= tc.description %></strong>
          <span class="badge bg-secondary">Position <%= tc.position %></span>
        </div>
        <div class="row">
          <div class="col-md-6">
            <p style="font-size: 0.75rem; font-weight: 600; color: #555; margin-bottom: 4px;">INPUT PINS</p>
            <div style="background: #e8f5e9; padding: 8px; border-radius: 4px;">
              <table class="table table-sm mb-0" style="font-size: 0.8rem;">
                <thead>
                  <tr><th>Pin</th><th>Value</th></tr>
                </thead>
                <tbody>
                  <% tc.input_pins.each do |pin, val| %>
                    <tr><td><code><%= pin %></code></td><td><%= val %></td></tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
          <div class="col-md-6">
            <p style="font-size: 0.75rem; font-weight: 600; color: #555; margin-bottom: 4px;">EXPECTED OUTPUT</p>
            <div style="background: #e3f2fd; padding: 8px; border-radius: 4px;">
              <table class="table table-sm mb-0" style="font-size: 0.8rem;">
                <thead>
                  <tr><th>Pin</th><th>Value</th></tr>
                </thead>
                <tbody>
                  <% tc.expected_output.each do |pin, val| %>
                    <tr><td><code><%= pin %></code></td><td><%= val %></td></tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <% if user_signed_in? && @template.created_by_id == current_user.id %>
          <div class="text-end mt-2">
            <%= link_to "Delete", circuit_template_assignment_test_case_path(@template, tc),
                method: :delete,
                data: { confirm: "Remove this test case?" },
                class: "mini-button groups-delete-mini-button" %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── USED IN ASSIGNMENTS ─────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
    <h3 class="mb-0">Used in Assignments</h3>
  </div>
  <hr>

  <% if @assignments_using.empty? %>
    <span class="null-text">This template has not been used in any assignments yet.</span>
  <% else %>
    <table class="table table-borderless groups-table">
      <thead class="groups-table-heading">
        <tr>
          <th>Assignment Name</th>
          <th>Classroom</th>
          <th>Due Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @assignments_using.each do |a| %>
          <tr class="groups-table-rows">
            <td><%= a.name %></td>
            <td><%= a.group.name %></td>
            <td>
              <% if a.deadline %>
                <%= a.deadline.strftime("%b %d, %Y") %>
              <% else %>
                <span class="null-text">&mdash;</span>
              <% end %>
            </td>
            <td>
              <%= link_to "View", group_assignment_path(a.group, a), class: "mini-button groups-view-mini-button" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <div class="row mt-4">
    <div class="col-12">
      <%= link_to "Back to Library", circuit_templates_path, class: "anchor-text" %>
    </div>
  </div>
</div>

<%# ── ADD TEST CASE MODAL ─────────────────────────────────────── %>
<% if user_signed_in? && @template.created_by_id == current_user.id && @assignments_using.any? %>
  <div class="modal fade" id="addTestCaseModal" tabindex="-1" aria-labelledby="addTestCaseModalLabel" aria-hidden="true">
    <div class="modal-dialog primary-modal-dialog">
      <div class="modal-content">
        <div class="modal-header primary-modal-header">
          <h5 class="modal-title" id="addTestCaseModalLabel">Add Test Case</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <%= form_with url: assignment_test_cases_path, method: :post do |f| %>
            <%= f.hidden_field :assignment_id, value: @assignments_using.first.id %>
            <div class="mb-3">
              <%= f.label :description, "Description", class: "form-label" %>
              <%= f.text_field :description, class: "form-control form-input", required: true %>
            </div>
            <div class="mb-3">
              <%= f.label :position, "Position", class: "form-label" %>
              <%= f.number_field :position, class: "form-control form-input", value: 1, min: 0 %>
            </div>
            <div class="mb-3">
              <%= f.label :input_pins, "Input Pins (JSON)", class: "form-label" %>
              <%= f.text_area :input_pins, class: "form-control form-input", rows: 3,
                  placeholder: '{"A": 1, "B": 1}' %>
            </div>
            <div class="mb-3">
              <%= f.label :expected_output, "Expected Output (JSON)", class: "form-label" %>
              <%= f.text_area :expected_output, class: "form-control form-input", rows: 3,
                  placeholder: '{"Y": 1}' %>
            </div>
            <div class="text-end">
              <button type="button" class="btn mini-button groups-close-mini-button" data-bs-dismiss="modal">Cancel</button>
              <%= f.submit "Add Test Case", class: "btn primary-button" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
